{
  "permissions": {
    "allow": [
      "Bash(git diff *)",
      "Bash(git * diff *)",
      "Bash(grep *)",
      "Bash(printf *)",
      "Bash(echo *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/beep"
          }
        ]
      }
    ]
  }
}
