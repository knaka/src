{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "\"$CLAUDE_PROJECT_DIR\"/mise run hooks:log"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "\"$CLAUDE_PROJECT_DIR\"/mise run hooks:log"
          }
        ]
      }
    ]
  }
}
